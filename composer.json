{
  "name": "rllngr/kirby-llmsizer",
  "description": "Kirby plugin to generate /llms.txt and /llms-sitemap.xml for AI search engines. Works in both classic and headless mode.",
  "type": "kirby-plugin",
  "license": "MIT",
  "authors": [
    {
      "name": "Nicolas Rollinger",
      "email": "contact@rollinger.design",
      "homepage": "https://rollinger.design",
      "role": "Developer"
    }
  ],
  "keywords": [
    "kirby",
    "kirby-plugin",
    "llms",
    "llms.txt",
    "sitemap",
    "geo",
    "generative engine optimization",
    "ai",
    "seo"
  ],
  "homepage": "https://github.com/rllngr/kirby-llmsizer",
  "support": {
    "issues": "https://github.com/rllngr/kirby-llmsizer/issues",
    "source": "https://github.com/rllngr/kirby-llmsizer"
  },
  "require": {
    "php": ">=8.1",
    "getkirby/composer-installer": "^1.0"
  },
  "require-dev": {
    "getkirby/cms": "^4.0 || ^5.0"
  },
  "autoload": {
    "psr-4": {
      "Rllngr\\KirbyLlmsizer\\": "src/"
    }
  },
  "extra": {
    "installer-name": "kirby-llmsizer"
  }
}
